{
  "manifest_version": 3,
  "name": "COVE PM12 Daily Export",
  "version": "0.1.0",
  "description": "One-click sort + export of Cove PM12, renamed to COVE PM12 YYYY-MM-DD.csv and routed into a Drive-synced folder.",
  "permissions": ["downloads", "storage", "tabs", "alarms"],
  "host_permissions": ["https://manage.cove.is/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Run Daily PM12 Export",
    "default_popup": "popup.html"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["https://manage.cove.is/networks/*/pm-tasks*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "world": "MAIN"
    }
  ]
}
