# COVE CSV watcher configuration
# Copy this file to `.env` (same directory) and fill in real values.
# Do NOT commit .env — it is .gitignored.

# From Supabase dashboard → Project Settings → API
SUPABASE_URL=https://iujuibvcahuapzowjtym.supabase.co

# Service-role key (NOT the publishable/anon key). Found under:
#   Project Settings → API → Project API keys → service_role
# This key bypasses RLS — never ship it to a browser.
SUPABASE_SERVICE_KEY=replace_with_service_role_key

# Absolute path of the folder to watch for incoming CSVs.
WATCH_DIR=D:\Dashboard PMs WOs Events Claude made\CSV DB

# ---- Phase 5 (direct Cove API) ----
# Bearer JWT copied from a live Cove session. DevTools → Network → any
# api.cove.is/gql request → Headers → Authorization (drop the "Bearer " prefix).
# Tokens expire after ~7 days; we'll add a refresh flow in Phase 5.3.
COVE_AUTH_TOKEN=replace_with_jwt_no_bearer_prefix

# Your Cove network ID (from the URL: /networks/<this>/...).
COVE_NETWORK_ID=OoxMP8BZJF
