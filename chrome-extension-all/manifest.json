{
  "manifest_version": 3,
  "name": "COVE Daily Exports (PM12 + WO12)",
  "version": "0.3.0",
  "description": "One-click PM12 + WO12 daily exports. Labor moved to the Python API poller (watcher/labor_poller.py).",
  "permissions": ["downloads", "storage", "tabs", "alarms"],
  "host_permissions": ["https://manage.cove.is/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "COVE Daily Exports",
    "default_popup": "popup.html"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["https://manage.cove.is/networks/*/pm-tasks*"],
      "js": ["content-pm.js"],
      "run_at": "document_idle",
      "world": "MAIN"
    },
    {
      "matches": ["https://manage.cove.is/networks/*"],
      "exclude_matches": [
        "https://manage.cove.is/networks/*/pm-tasks*",
        "https://manage.cove.is/networks/*/work-order-labor-reports*"
      ],
      "js": ["content-wo.js"],
      "run_at": "document_idle",
      "world": "MAIN"
    }
  ]
}
